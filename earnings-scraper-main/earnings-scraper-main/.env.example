# --- Headless extraction (stream driver="claude") ---
# Anthropic key. Set it here/in the env, or drop it in secrets/anthropic_api
# (config.py + scripts/env_setup.sh load that file into ANTHROPIC_API_KEY).
ANTHROPIC_API_KEY=
